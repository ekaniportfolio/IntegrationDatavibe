{
  "name": "@spatial-flow/core",
  "version": "3.1.0",
  "description": "Spatial Flow -- A post-flat UI animation architecture where every transition encodes spatial direction. Physics-based, accessible, speed-controllable. Now with createProtocol() for agnostic protocol creation.",
  "author": "Michel EKANI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs",
      "types": "./dist/hooks/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs",
      "types": "./dist/components/index.d.ts"
    },
    "./viewport-lock.css": "./src/core/viewport-lock.css",
    "./reduced-motion.css": "./src/core/reduced-motion.css"
  },
  "files": [
    "dist",
    "src/core/viewport-lock.css",
    "src/core/reduced-motion.css",
    "README.md",
    "INSTALL.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "motion": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "motion": {
      "optional": false
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "keywords": [
    "spatial-flow",
    "animation",
    "motion",
    "framer-motion",
    "react",
    "ui",
    "physics",
    "spring",
    "transition",
    "accessibility",
    "reduced-motion",
    "wcag",
    "design-system",
    "post-flat",
    "visiomorphism",
    "chrysalis-shift",
    "lateral-glide",
    "sequential-cascade"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/spatial-flow/spatial-flow"
  },
  "bugs": {
    "url": "https://github.com/spatial-flow/spatial-flow/issues"
  },
  "homepage": "https://github.com/spatial-flow/spatial-flow#readme",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}